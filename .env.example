# ═══════════════════════════════════════════════════════════
# Gemini Flash API - Environment Variables
# ═══════════════════════════════════════════════════════════

# ── API Keys ───────────────────────────────────────────────
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server Configuration ───────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Security ───────────────────────────────────────────────
# Generate a strong secret key for JWT
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string

# Optional: API key for external access (leave empty to disable)
API_KEY=

# ── Logging ────────────────────────────────────────────────
# Options: error, warn, info, debug
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────
# Backup schedule (cron format)
# Default: 0 2 * * * (Daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *

# ── Optional: Cloud Storage (AWS S3) ───────────────────────
# Uncomment if you want to use S3 for file storage
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ── Optional: Redis Cache ──────────────────────────────────
# Uncomment if you want to use Redis instead of in-memory cache
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Optional: Email Notifications ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ── Optional: Webhook ──────────────────────────────────────
# WEBHOOK_URL=https://your-webhook-url.com/endpoint
