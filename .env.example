# ═══════════════════════════════════════════════════════════
# Gemini Flash API - Environment Variables
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# ✅ WAJIB DIISI — App tidak jalan tanpa ini
# ═══════════════════════════════════════════════════════════

# Dapatkan API key dari: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════
# ⚙️ OPTIONAL — Sudah ada default value, ubah kalau perlu
# ═══════════════════════════════════════════════════════════

PORT=3000                    # Default: 3000
NODE_ENV=development         # Default: development
LOG_LEVEL=info               # Options: error, warn, info, debug

# Generate JWT secret dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Kalau tidak diisi, pakai default (cukup untuk development)
# JWT_SECRET=your_random_secret_here
