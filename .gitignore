# ═══════════════════════════════════════════════════════════
# Gemini Flash API - .gitignore
# ═══════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/
package-lock.json
package.json

# ── Environment Variables (SENSITIVE!) ──
.env
.env.local
.env.production
.env.*.local

# ── Database Files (auto-generated at runtime) ──
database/*.db
database/*.db-shm
database/*.db-wal

# ── Logs (auto-generated at runtime) ──
logs/

# ── Backups ──
backups/

# ── Uploads (user files) ──
uploads/*
!uploads/.gitkeep

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ──
.vscode/
.idea/
*.swp
*.swo
*~