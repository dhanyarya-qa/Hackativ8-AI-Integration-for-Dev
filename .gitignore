# ═══════════════════════════════════════════════════════════
# Gemini Flash API - .gitignore
# ═══════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/
package-lock.json

# ── Environment Variables (SENSITIVE!) ──
.env
.env.local
.env.production
.env.*.local

# ── Database Files (Contains user data) ──
*.db
*.db-shm
*.db-wal
chatbot.db*
analytics.db*
auth.db*

# ── Logs (May contain sensitive info) ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Backups (Contains database dumps) ──
backups/
*.zip
*.tar.gz

# ── Uploads (User uploaded files) ──
uploads/*
!uploads/.gitkeep

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Build Files ──
dist/
build/
*.tsbuildinfo

# ── Test Coverage ──
coverage/
.nyc_output/

# ── Temporary Files ──
tmp/
temp/
*.tmp

# ── API Keys & Secrets (IMPORTANT!) ──
*.pem
*.key
*.cert
secrets.json
credentials.json

# ── Local Config ──
config.local.js
.env.development.local
.env.test.local
.env.production.local/